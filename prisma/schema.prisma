generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  posts Post[]
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String
  published Boolean @default(false)
  authorId  Int
  author    User    @relation(fields: [authorId], references: [id])
}

model Event {
  id            Int      @id @default(autoincrement())
  title         String
  date          DateTime
  time          DateTime @db.Timestamptz(3)
  venue         String
  type          String
  signupLink    String
  catering      String
  collaborators String[]
  description   String
  image_data    Bytes?
  mime_type     String?
}

model LinkClick {
  id        Int      @id @default(autoincrement())
  label     String
  url       String?
  page      String
  referrer  String?
  sessionId String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([label])
  @@index([page])
 
}

model PageView {
  id        Int      @id @default(autoincrement())
  page      String
  referrer  String?
  sessionId String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([page])
}
