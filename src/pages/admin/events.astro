---
import Layout from "../../layouts/Layout.astro";
import EventManager from "../../components/EventManager.jsx";
---

<Layout title="Event Management | SUDATA">
  <main class="min-h-screen bg-[#020617] pt-20 pb-20 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto space-y-12">
      <header class="text-center space-y-4 reveal-on-scroll">
        <h1 class="text-4xl sm:text-6xl font-bold text-[#00F0FF] tracking-widest font-mono uppercase" style="text-shadow: 0 0 15px #00F0FF;">
          Event Catalog
        </h1>
        <p class="text-[#00F0FF]/80 text-sm sm:text-base font-mono">
          Manage the latest events in the SUDATA universe.
        </p>
        <div class="flex flex-wrap justify-center gap-3 pt-2">
          <a href="/events" class="px-4 py-2 border border-[#00F0FF]/40 text-[#00F0FF] text-xs font-mono tracking-[0.18em] uppercase hover:bg-[#00F0FF] hover:text-[#020617] transition-all">
            View as Member
          </a>
          <button
            id="admin-logout-btn"
            class="px-4 py-2 border border-red-400/50 text-red-300 text-xs font-mono tracking-[0.18em] uppercase hover:bg-red-500 hover:text-white transition-all"
          >
            Admin Logout
          </button>
        </div>
      </header>

      <EventManager client:load />
    </div>
  </main>
</Layout>

<style is:global>
  .label-neon {
    @apply flex items-center gap-2 text-[#00F0FF] text-[10px] tracking-[0.2em] uppercase font-bold mb-2;
  }

  .input-field {
    @apply w-full bg-slate-900/60 border border-[#00F0FF]/20 p-4 text-white
           placeholder:text-white/20 font-mono text-sm
           focus:outline-none focus:border-[#00F0FF] focus:bg-slate-900/90
           transition-all duration-300;
  }

  .submit-btn {
    @apply w-full flex items-center justify-center gap-4 bg-[#00F0FF] text-[#020617]
           font-bold py-4 tracking-[0.4em] uppercase transition-all duration-300
           shadow-[0_0_20px_rgba(0,240,255,0.4)];
  }

  .submit-btn:hover {
    @apply bg-white shadow-[0_0_30px_white] -translate-y-1;
  }

  .reveal-on-scroll {
    animation: reveal-view cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-timeline: view();
    animation-range: entry 5% cover 20%;
  }

  @keyframes reveal-view {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script is:inline>
  document.getElementById("admin-logout-btn")?.addEventListener("click", async () => {
    await fetch("/api/admin/logout", { method: "POST" });
    window.location.assign("/admin/login");
  });
</script>
