---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import prisma from "../../lib/prisma";

const days = parseInt(Astro.url.searchParams.get("days") || "30");
const since = new Date(Date.now() - days * 24 * 60 * 60 * 1000);
const prevSince = new Date(since.getTime() - days * 24 * 60 * 60 * 1000);

const tzParam = Astro.url.searchParams.get("tz") ?? "";
const validTz = /^[A-Za-z_]+(?:\/[A-Za-z_]+(?:\/[A-Za-z_]+)?)?$/.test(tzParam) ? tzParam : "UTC";

const [
  clicksByLabel,
  pageviews,
  totalClicks,
  totalPageviews,
  prevTotalClicks,
  prevTotalPageviews,
  sponsorOutboundClicks,
  eventSignupClicks,
] = await Promise.all([
  prisma.linkClick.groupBy({
    by: ["label"],
    where: { createdAt: { gte: since } },
    _count: { id: true },
    orderBy: { _count: { id: "desc" } },
  }),
  prisma.pageView.groupBy({
    by: ["page"],
    where: { createdAt: { gte: since } },
    _count: { id: true },
    orderBy: { _count: { id: "desc" } },
  }),
  prisma.linkClick.count({ where: { createdAt: { gte: since } } }),
  prisma.pageView.count({ where: { createdAt: { gte: since } } }),
  prisma.linkClick.count({ where: { createdAt: { gte: prevSince, lt: since } } }),
  prisma.pageView.count({ where: { createdAt: { gte: prevSince, lt: since } } }),
  prisma.linkClick.count({ where: { createdAt: { gte: since }, page: "/sponsors", label: { startsWith: "sponsor-page:" } } }),
  prisma.linkClick.count({ where: { createdAt: { gte: since }, page: "/events", label: { startsWith: "event-signup:" } } }),
]);

const [uniqueClickSessions, uniqueViewSessions, prevUniqueViewSessions] = await Promise.all([
  prisma.linkClick.findMany({
    where: { createdAt: { gte: since }, sessionId: { not: null } },
    select: { sessionId: true },
    distinct: ["sessionId"],
  }),
  prisma.pageView.findMany({
    where: { createdAt: { gte: since }, sessionId: { not: null } },
    select: { sessionId: true },
    distinct: ["sessionId"],
  }),
  prisma.pageView.findMany({
    where: { createdAt: { gte: prevSince, lt: since }, sessionId: { not: null } },
    select: { sessionId: true },
    distinct: ["sessionId"],
  }),
]);

const dailyViewsRaw = await prisma.$queryRaw<Array<{ day: string; count: number }>>`
  SELECT
    TO_CHAR(local_day, 'YYYY-MM-DD') AS day,
    COUNT(*)::int AS count
  FROM (
    SELECT DATE_TRUNC('day', "createdAt"::TIMESTAMPTZ AT TIME ZONE ${validTz}) AS local_day
    FROM "PageView"
    WHERE "createdAt" >= ${since}
  ) sub
  GROUP BY local_day
  ORDER BY local_day ASC
`;

const isoInTz = (d: Date) =>
  new Intl.DateTimeFormat("sv", { timeZone: validTz, year: "numeric", month: "2-digit", day: "2-digit" }).format(d);
const pvDbMap = new Map(dailyViewsRaw.map((r) => [r.day, Number(r.count)]));
const pvIsoLabels: string[] = [];
const pvCounts: number[] = [];
const todayIso = isoInTz(new Date());
const DAY_MS = 86_400_000;
for (let ms = since.getTime() + DAY_MS / 2; ; ms += DAY_MS) {
  const iso = isoInTz(new Date(ms));
  if (!pvIsoLabels.length || pvIsoLabels[pvIsoLabels.length - 1] !== iso) {
    pvIsoLabels.push(iso);
    pvCounts.push(pvDbMap.get(iso) ?? 0);
  }
  if (iso === todayIso) break;
  if (ms > Date.now() + 2 * DAY_MS) break;
}
const MONTHS_SHORT = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
const pvDisplayLabels = pvIsoLabels.map((iso) => {
  const [, m, d] = iso.split("-");
  return `${d} ${MONTHS_SHORT[+m - 1]}`;
});

const uniqueVisitors = new Set([...uniqueViewSessions.map((r) => r.sessionId), ...uniqueClickSessions.map((r) => r.sessionId)]).size;
const prevUniqueVisitors = new Set(prevUniqueViewSessions.map((r) => r.sessionId)).size;

const sponsorsPageViews = pageviews.find((p) => p.page === "/sponsors")?._count.id ?? 0;
const eventsPageViews = pageviews.find((p) => p.page === "/events")?._count.id ?? 0;
const sponsorsRate = sponsorsPageViews > 0 ? Math.round((sponsorOutboundClicks / sponsorsPageViews) * 100) : null;
const eventsRate = eventsPageViews > 0 ? Math.round((eventSignupClicks / eventsPageViews) * 100) : null;

function trend(current: number, previous: number): string | null {
  if (previous === 0) return null;
  const pct = Math.round(((current - previous) / previous) * 100);
  return (pct >= 0 ? "+" : "") + pct + "%";
}
function trendDir(current: number, previous: number): "up" | "down" | "flat" {
  if (previous === 0 || current === previous) return "flat";
  return current > previous ? "up" : "down";
}
function slugToTitle(slug: string) {
  return slug.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
}
const CATEGORIES = [
  { prefix: "sponsor-page:", name: "Sponsor Page", color: "#00F0FF", desc: "A visitor clicked through to a sponsor's website from the Sponsors page." },
  { prefix: "sponsor-opp:", name: "Sponsor Opportunity", color: "#22c55e", desc: "A visitor clicked on a career opportunity or internship posted by a sponsor on the Careers page." },
  { prefix: "event-detail:", name: "Event Detail", color: "#8b5cf6", desc: "A visitor opened an event card in the calendar to read its full details." },
  { prefix: "event-signup:", name: "Event Signup", color: "#f59e0b", desc: "A visitor clicked the registration or signup link for a specific event." },
  { prefix: "download:", name: "Download", color: "#f472b6", desc: "A visitor downloaded a file such as the First Year Guide or Sponsorship Prospectus." },
  { prefix: "contact:", name: "Contact & Socials", color: "#38bdf8", desc: "A visitor clicked a social media link, LinkedIn profile, or a join/contact button." },
  { prefix: "nav:", name: "Navigation", color: "#64748b", desc: "A visitor clicked a navigation link, such as the Membership button in the header." },
];
function parseLabel(label: string) {
  for (const cat of CATEGORIES) {
    if (label.startsWith(cat.prefix)) {
      const raw = label.slice(cat.prefix.length).split(":")[0];
      return { name: slugToTitle(raw), category: cat.name, color: cat.color };
    }
  }
  return { name: label, category: "Other", color: "#9ca3af" };
}
const byCategory = CATEGORIES.map((cat) => {
  const count = clicksByLabel.filter((r) => r.label.startsWith(cat.prefix)).reduce((sum, r) => sum + r._count.id, 0);
  return { name: cat.name, count, color: cat.color, desc: cat.desc };
})
  .filter((c) => c.count > 0)
  .sort((a, b) => b.count - a.count);
function pageName(path: string) {
  const map: Record<string, string> = {
    "/": "Home",
    "/sponsors": "Sponsors",
    "/events": "Events",
    "/careers": "Careers",
    "/about": "About",
    "/photos": "Photos",
    "/docs": "Docs",
  };
  return map[path] ?? path;
}
const engagementRate = totalPageviews > 0 ? Math.round((totalClicks / totalPageviews) * 100) : 0;
const topPage = pageviews[0] ? pageName(pageviews[0].page) : "—";
const topPageCount = pageviews[0]?._count.id ?? 0;
const topClickParsed = clicksByLabel[0] ? parseLabel(clicksByLabel[0].label) : null;
const topClickName = topClickParsed?.name ?? "—";
const topClickCount = clicksByLabel[0]?._count.id ?? 0;

const chartPayload = {
  pv: { labels: pvDisplayLabels, data: pvCounts },
  outbound: clicksByLabel.slice(0, 8).map((r) => {
    const p = parseLabel(r.label);
    return { name: p.name, count: r._count.id, color: p.color, category: p.category };
  }),
  donut: byCategory.map((c) => ({ name: c.name, count: c.count, color: c.color })),
  topPages: pageviews.slice(0, 6).map((r) => ({
    name: pageName(r.page),
    path: r.page,
    count: r._count.id,
    share: totalPageviews > 0 ? Math.round((r._count.id / totalPageviews) * 100) : 0,
  })),
};
---

<Layout title="Analytics | SUDATA">
  <main class="admin-analytics-page">
    <script is:inline>
      (function () {
        const url = new URL(window.location.href);
        if (!url.searchParams.has("tz")) {
          const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
          url.searchParams.set("tz", tz);
          window.location.replace(url.toString());
        }
      })();
    </script>

    <section class="analytics-topbar">
      <div class="analytics-topbar-left">
        <div>
          <h1 class="analytics-wordmark">Website Analytics</h1>
          <p class="analytics-sub">Internal dashboard · {validTz}</p>
        </div>
        <span class="analytics-refresh-age" id="refresh-age">updated just now</span>
      </div>
      <div class="analytics-actions">
        <a href="/admin" class="analytics-action-link">Admin Hub</a>
        {[7, 30, 90].map((d) => (
          <a href={`?days=${d}&tz=${encodeURIComponent(validTz)}`} class={`range-tab${days === d ? " active" : ""}`}>{d}d</a>
        ))}
      </div>
    </section>

    <script is:inline define:vars={{ renderedAt: Date.now() }}>
      (function () {
        const el = document.getElementById("refresh-age");
        if (!el) return;
        function tick() {
          const secs = Math.floor((Date.now() - renderedAt) / 1000);
          if (secs < 10) el.textContent = "updated just now";
          else if (secs < 60) el.textContent = `updated ${secs}s ago`;
          else if (secs < 3600) el.textContent = `updated ${Math.floor(secs / 60)}m ago`;
          else el.textContent = `updated ${Math.floor(secs / 3600)}h ago`;
        }
        tick();
        setInterval(tick, 10000);
      })();
    </script>

    <div class="dashboard">
      <div class="kpi-row">
        <div class="kpi-card">
          <div class="kpi-label">Page Views</div>
          <div class="kpi-value">{totalPageviews.toLocaleString()}</div>
          <div class={trend(totalPageviews, prevTotalPageviews) ? `kpi-trend ${trendDir(totalPageviews, prevTotalPageviews)}` : "kpi-trend flat"}>
            {trend(totalPageviews, prevTotalPageviews)
              ? `${trendDir(totalPageviews, prevTotalPageviews) === "up" ? "↑" : "↓"} ${trend(totalPageviews, prevTotalPageviews)} vs prior`
              : "— no prior data yet"}
          </div>
          <div class="kpi-sub">Top: {topPage} ({topPageCount.toLocaleString()} views)</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">Outbound Clicks</div>
          <div class="kpi-value">{totalClicks.toLocaleString()}</div>
          <div class={trend(totalClicks, prevTotalClicks) ? `kpi-trend ${trendDir(totalClicks, prevTotalClicks)}` : "kpi-trend flat"}>
            {trend(totalClicks, prevTotalClicks)
              ? `${trendDir(totalClicks, prevTotalClicks) === "up" ? "↑" : "↓"} ${trend(totalClicks, prevTotalClicks)} vs prior`
              : "— no prior data yet"}
          </div>
          <div class="kpi-sub">{engagementRate}% outbound click-through rate</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">Unique Visitors</div>
          <div class="kpi-value">{uniqueVisitors > 0 ? uniqueVisitors.toLocaleString() : "—"}</div>
          <div class={uniqueVisitors > 0 && prevUniqueVisitors > 0 ? `kpi-trend ${trendDir(uniqueVisitors, prevUniqueVisitors)}` : "kpi-trend flat"}>
            {uniqueVisitors > 0 && prevUniqueVisitors > 0
              ? `${trendDir(uniqueVisitors, prevUniqueVisitors) === "up" ? "↑" : "↓"} ${trend(uniqueVisitors, prevUniqueVisitors)} vs prior`
              : "— no prior data yet"}
          </div>
          <div class="kpi-sub">Approx. — per device/browser (cookie), or per tab if declined</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">Top Link</div>
          <div class="kpi-value top-link">{topClickName}</div>
          <div class="kpi-sub">{topClickCount.toLocaleString()} clicks (last {days}d)</div>
        </div>
      </div>

      <div class="grid-row grid-2-1">
        <div class="panel">
          <div class="panel-header">
            <span class="panel-title">Page views over time</span>
          </div>
          <div class="panel-body">
            {chartPayload.pv.labels.length === 0 ? <div class="empty">No data for this period yet</div> : <div class="chart-wrap"><div class="chart-inner pv-inner"><canvas id="pv-chart"></canvas></div></div>}
          </div>
        </div>
        <div class="panel">
          <div class="panel-header"><span class="panel-title">Top pages</span></div>
          <div class="panel-body">
            {chartPayload.topPages.length === 0 ? (
              <div class="empty">No data yet</div>
            ) : (
              <div class="pages-list">
                {chartPayload.topPages.map((p) => (
                  <div class="page-row">
                    <div class="page-row-top">
                      <span class="page-name">{p.name}</span>
                      <div class="page-meta">
                        <span class="page-share">{p.share}%</span>
                        <span class="page-count">{p.count.toLocaleString()}</span>
                      </div>
                    </div>
                    <div class="page-bar-bg"><div class="page-bar-fill" style={`width:${p.share}%`}></div></div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>

      <div class="grid-row grid-2-1">
        <div class="panel">
          <div class="panel-header"><span class="panel-title">Outbound link clicks</span></div>
          <div class="panel-body">
            {chartPayload.outbound.length === 0 ? <div class="empty">No click data yet</div> : <div class="chart-wrap"><div class="chart-inner ob-inner"><canvas id="outbound-chart"></canvas></div></div>}
          </div>
        </div>
        <div class="panel">
          <div class="panel-header"><span class="panel-title">Clicks by category</span></div>
          <div class="panel-body">
            {byCategory.length === 0 ? (
              <div class="empty">No click data yet</div>
            ) : (
              <div class="donut-wrap">
                <div class="chart-inner donut-inner"><canvas id="donut-chart"></canvas></div>
                <div class="donut-legend">
                  {byCategory.map((cat) => {
                    const pct = totalClicks > 0 ? Math.round((cat.count / totalClicks) * 100) : 0;
                    return (
                      <div class="legend-row">
                        <div class="legend-dot" style={`background:${cat.color}`}></div>
                        <span class="legend-name">{cat.name}</span>
                        <span class="legend-count">{cat.count}</span>
                        <span class="legend-pct">{pct}%</span>
                      </div>
                    );
                  })}
                </div>
              </div>
            )}
            {(sponsorsPageViews > 0 || eventsPageViews > 0) && (
              <div class="signals-section">
                <div class="signals-header">Click-through rates</div>
                <div class="signal-row">
                  <div>
                    <div class="signal-label">Sponsors page</div>
                    <div class="signal-sub">sponsor clicks / sponsors page views</div>
                  </div>
                  {sponsorsRate !== null ? <div class="signal-value">{sponsorsRate}%</div> : <div class="signal-value dim">no data</div>}
                </div>
                <div class="signal-row">
                  <div>
                    <div class="signal-label">Events page</div>
                    <div class="signal-sub">event signups / events page views</div>
                  </div>
                  {eventsRate !== null ? <div class="signal-value">{eventsRate}%</div> : <div class="signal-value dim">no data</div>}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .admin-analytics-page { color: #94a3b8; font-family: "JetBrains Mono", ui-monospace, monospace; }
  .analytics-topbar { margin-top: 1.25rem; border: 1px solid rgba(0,240,255,0.18); background: rgba(10,22,40,0.85); padding: 1rem 1.25rem; display: flex; justify-content: space-between; gap: 1rem; align-items: center; flex-wrap: wrap; }
  .analytics-wordmark { color: #e2e8f0; font-size: 1rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; }
  .analytics-sub { font-size: 0.72rem; color: #64748b; margin-top: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .analytics-refresh-age { font-size: 0.72rem; color: #64748b; }
  .analytics-topbar-left { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .analytics-actions { display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap; }
  .analytics-action-link { border: 1px solid rgba(255,255,255,0.18); color: #cbd5e1; font-size: 0.72rem; padding: 0.32rem 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; text-decoration: none; }
  .analytics-action-link:hover { background: rgba(255,255,255,0.07); color: #fff; }
  .range-tab { text-decoration: none; padding: 0.32rem 0.6rem; font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: #64748b; border: 1px solid transparent; }
  .range-tab:hover { color: #00f0ff; border-color: rgba(0,240,255,0.2); }
  .range-tab.active { color: #00f0ff; background: rgba(0,240,255,0.12); border-color: rgba(0,240,255,0.4); }
  .dashboard { padding: 1rem 0 0.6rem; display: flex; flex-direction: column; gap: 0.8rem; }
  .kpi-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 0.8rem; }
  .kpi-card { background: #0a1628; border: 1px solid rgba(0,240,255,0.18); padding: 0.9rem 1rem; display: flex; flex-direction: column; gap: 0.2rem; }
  .kpi-label { font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: #64748b; }
  .kpi-value { font-size: 1.9rem; color: #e2e8f0; line-height: 1; margin-top: 0.25rem; font-weight: 700; }
  .kpi-value.top-link { font-size: 0.95rem; line-height: 1.3; }
  .kpi-trend { font-size: 0.72rem; margin-top: 0.25rem; }
  .kpi-trend.up { color: #34d399; } .kpi-trend.down { color: #f87171; } .kpi-trend.flat { color: #64748b; }
  .kpi-sub { font-size: 0.67rem; color: #64748b; margin-top: 0.25rem; }
  .grid-row { display: grid; gap: 0.8rem; }
  .grid-2-1 { grid-template-columns: 2fr 1fr; }
  .panel { background: #0a1628; border: 1px solid rgba(0,240,255,0.18); display: flex; flex-direction: column; }
  .panel-header { padding: 0.8rem 1rem; border-bottom: 1px solid rgba(0,240,255,0.08); }
  .panel-title { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #64748b; }
  .panel-body { flex: 1; display: flex; flex-direction: column; }
  .chart-wrap { padding: 0.9rem 1rem; } .chart-wrap .chart-inner { position: relative; }
  .pv-inner { height: 240px; } .ob-inner { height: 220px; } .donut-inner { height: 120px; width: 120px; }
  .pages-list { padding: 0.85rem 1rem; display: flex; flex-direction: column; gap: 0.9rem; max-height: 320px; overflow-y: auto; }
  .page-row-top { display: flex; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.3rem; }
  .page-name { font-size: 0.8rem; color: #e2e8f0; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .page-meta { display: flex; gap: 0.8rem; } .page-share { font-size: 0.68rem; color: #64748b; } .page-count { font-size: 0.78rem; color: #94a3b8; }
  .page-bar-bg { height: 2px; background: rgba(255,255,255,0.06); } .page-bar-fill { height: 100%; background: #00f0ff; opacity: 0.6; transition: width 0.5s ease; }
  .donut-wrap { padding: 0.9rem 1rem; display: flex; gap: 1.1rem; align-items: center; }
  .donut-legend { flex: 1; display: flex; flex-direction: column; gap: 0.55rem; }
  .legend-row { display: flex; align-items: center; gap: 0.4rem; } .legend-dot { width: 8px; height: 8px; border-radius: 50%; }
  .legend-name { font-size: 0.68rem; color: #94a3b8; flex: 1; } .legend-count { font-size: 0.72rem; color: #e2e8f0; font-weight: 600; } .legend-pct { font-size: 0.62rem; color: #64748b; width: 30px; text-align: right; }
  .empty { padding: 1.4rem 1rem; text-align: center; color: #64748b; font-size: 0.72rem; letter-spacing: 0.05em; }
  .signals-section { border-top: 1px solid rgba(0,240,255,0.08); padding: 0.8rem 1rem; display: flex; flex-direction: column; gap: 0.7rem; }
  .signals-header { font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase; color: #64748b; }
  .signal-row { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; }
  .signal-label { font-size: 0.75rem; color: #e2e8f0; } .signal-sub { font-size: 0.62rem; color: #64748b; margin-top: 0.12rem; }
  .signal-value { font-size: 1.2rem; font-weight: 700; color: #00f0ff; } .signal-value.dim { color: #64748b; font-size: 0.78rem; font-weight: 400; }
  @media (max-width: 1100px) { .kpi-row { grid-template-columns: repeat(2,1fr); } .grid-2-1 { grid-template-columns: 1fr; } }
  @media (max-width: 640px) { .kpi-row { grid-template-columns: 1fr; } .analytics-topbar { padding: 0.8rem 0.9rem; } .kpi-value { font-size: 1.5rem; } }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script is:inline define:vars={{ chartPayload }}>
  const d = chartPayload;
  const NEON = "#00F0FF";
  const NAVY3 = "#0f1f3a";
  const GREY = "#94a3b8";
  const GREYDIM = "#475569";
  const WHITE = "#e2e8f0";
  const FONT = "'JetBrains Mono', monospace";

  const tooltipDefaults = (accent) => ({
    backgroundColor: NAVY3,
    borderColor: accent + "44",
    borderWidth: 1,
    titleColor: GREY,
    bodyColor: WHITE,
    titleFont: { family: FONT, size: 9 },
    bodyFont: { family: FONT, size: 12, weight: "600" },
    padding: 10,
  });

  const pvEl = document.getElementById("pv-chart");
  if (pvEl && d.pv.labels.length) {
    const ctx = pvEl.getContext("2d");
    const grad = ctx.createLinearGradient(0, 0, 0, 180);
    grad.addColorStop(0, NEON + "28");
    grad.addColorStop(1, NEON + "00");
    new Chart(ctx, {
      type: "line",
      data: { labels: d.pv.labels, datasets: [{ data: d.pv.data, borderColor: NEON, borderWidth: 1.5, pointRadius: d.pv.labels.length > 20 ? 0 : 2, pointHoverRadius: 4, pointBackgroundColor: NEON, tension: 0.4, fill: true, backgroundColor: grad }] },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: "index", intersect: false },
        plugins: { legend: { display: false }, tooltip: { ...tooltipDefaults(NEON), callbacks: { label: (ctx) => ` ${ctx.parsed.y.toLocaleString()} views` } } },
        scales: {
          x: { ticks: { color: GREYDIM, font: { family: FONT, size: 8 }, maxTicksLimit: 10, maxRotation: 0 }, grid: { display: false }, border: { display: false } },
          y: { ticks: { color: GREYDIM, font: { family: FONT, size: 8 }, callback: (v) => (v >= 1000 ? `${(v / 1000).toFixed(1)}k` : v) }, grid: { color: "rgba(255,255,255,0.04)" }, border: { display: false } },
        },
      },
    });
  }

  const obEl = document.getElementById("outbound-chart");
  if (obEl && d.outbound.length) {
    new Chart(obEl.getContext("2d"), {
      type: "bar",
      data: { labels: d.outbound.map((r) => r.name), datasets: [{ data: d.outbound.map((r) => r.count), backgroundColor: d.outbound.map((r) => r.color + "55"), borderColor: d.outbound.map((r) => r.color), borderWidth: 1, borderRadius: 1, borderSkipped: false }] },
      options: {
        indexAxis: "y",
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { ...tooltipDefaults(NEON), callbacks: { label: (ctx) => ` ${ctx.parsed.x.toLocaleString()} clicks`, afterLabel: (ctx) => ` ${d.outbound[ctx.dataIndex].category}` } } },
        scales: {
          x: { ticks: { color: GREYDIM, font: { family: FONT, size: 8 }, stepSize: 1, callback: (v) => (Number.isInteger(v) ? v : "") }, grid: { color: "rgba(255,255,255,0.04)" }, border: { display: false } },
          y: { ticks: { color: WHITE, font: { family: FONT, size: 9 } }, grid: { display: false }, border: { display: false } },
        },
      },
    });
  }

  const donutEl = document.getElementById("donut-chart");
  if (donutEl && d.donut.length) {
    new Chart(donutEl.getContext("2d"), {
      type: "doughnut",
      data: { labels: d.donut.map((r) => r.name), datasets: [{ data: d.donut.map((r) => r.count), backgroundColor: d.donut.map((r) => r.color + "66"), borderColor: d.donut.map((r) => r.color), borderWidth: 1.5, hoverOffset: 4 }] },
      options: { responsive: true, maintainAspectRatio: false, cutout: "70%", plugins: { legend: { display: false }, tooltip: { ...tooltipDefaults(NEON), callbacks: { label: (ctx) => ` ${ctx.parsed.toLocaleString()} clicks` } } } },
    });
  }
</script>
